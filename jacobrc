alias clear-aws='unset AWS_DEFAULT_REGION AWS_SECRET_ACCESS_KEY AWS_ACCESS_KEY_ID'
alias cls='clear'
alias co='codex --dangerously-bypass-approvals-and-sandbox'
# Strip blank lines and comment lines from piped text (good for trimming config files).
alias condense="grep -v '^\s*$' | grep -v '^#'"
# Quick CPU summary: model name, core count, and clock speed.
alias cpuinfo='egrep "model name|cores" /proc/cpuinfo|head -2; grep MHz /proc/cpuinfo | head -1'
alias cx='chmod +x'
# Docker shortcuts.
alias d='docker' 
alias dc='docker-compose' dcr='docker-compose restart'
# Disk free, human-readable, with filesystem type column.
alias dfh='df -hT'
