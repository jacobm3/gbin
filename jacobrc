alias dsh='du -sh'
alias dsk='du -sk'
# dn: disk usage (KB) of the given path, then sort numerically. $1 is the argument.
dn () { du -sk "$1" | sort -n; }

# ISO-8601 timestamp with colons (good for display).
alias d8601='date +%Y-%m-%dT%H:%M:%S%z'
# Same idea without colons (filename-safe). NOTE: plain var assignment, not an alias,
# so use it as `$ds` / `$($ds)`, not as a command.
ds='date +%Y-%m-%dT%H%M%S%z'


