# jacobrc — personal bash startup file (aliases, functions, prompt, PATH).
#
# This file is SOURCED, not executed: ~/.bashrc runs `. ~/gbin/jacobrc` so every
# line here runs inside your interactive shell. That is also why there is NO
# shebang (#!/bin/bash) line — adding one would do nothing useful and could be
# misleading, since the file is never run as its own program.
#
# HOW IT'S LOADED
#   setup-new-machine.sh appends `. ~/gbin/jacobrc` to ~/.bashrc, so it loads
#   automatically in every new login/interactive shell. To reload after editing,
#   run `. ~/gbin/jacobrc` (or use the `gu` alias defined below) or open a new shell.
#
# LAYOUT (top to bottom)
#   1. shell options, history, PATH, locale, TERM/color setup
#   2. prompt colors and PS1 definition
#   3. aliases (short names for common commands)
#   4. shell functions (small helpers that need arguments/logic)
#   5. completion setup and sourcing of other gbin helper scripts
#
# This file is synced to every machine by the hourly gbin pull, so anything here
# should be safe and useful everywhere. Per-machine tweaks go in ~/.jacobrc.local
# or ~/.bashrc.local, which are sourced at the very bottom.

# `vers` is a version/banner string shown at the right of the prompt. It hard-codes
# a date-style tag (v260621) plus the OS description from `lsb_release`. The pipe:
#   lsb_release -a   -> prints distro info (2>/dev/null hides the noisy warning)
#   grep Descrip     -> keep only the "Description:" line
#   sed 's/...//'    -> strip the "Description:" label + leading spaces, leaving the name
vers="v260621 `lsb_release -a 2>/dev/null | grep Descrip | sed 's/^Description:[[:space:]]*//'`"
# extglob enables extended glob patterns (e.g. ?(...), !(...)); some functions/
# completions below rely on it.
shopt -s extglob
# History settings, all exported so subshells inherit them:
#   HISTCONTROL=ignoreboth  -> ignore duplicate commands AND ones starting with a space
#   HISTSIZE=10000          -> keep 10k commands in memory
#   HISTTIMEFORMAT='%F %T ' -> prefix each history entry with a date+time stamp
#   HISTIGNORE=...          -> never record commands matching these globs, so secrets
#                              (AWS keys, vault tokens) don't get written to history
export HISTCONTROL=ignoreboth HISTSIZE=10000 HISTTIMEFORMAT='%F %T ' HISTIGNORE='*AWS_SECRET=:*AWS_SESSION=:*vault token*:*VAULT_TOKEN='
# Build PATH: keep whatever PATH already had, then append the user's own bin dirs
# (~/gbin, ~/bin, ~/.local/bin, ~/go/bin) and the standard system locations.
export PATH=$PATH:$HOME/gbin:$HOME/bin:$HOME/.local/bin:$HOME/go/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/bin/X11:/usr/X/bin:/var/lib/flatpak/exports/bin
# Scripts are organized into category subdirectories under ~/gbin; add each to
# PATH so they remain callable as bare commands after the repo reorg.
# Loop over every immediate subdirectory of ~/gbin (the trailing /*/ matches dirs only).
for _d in "$HOME"/gbin/*/; do
  # Surround PATH with colons and test whether this dir is already in it, so we
  # don't add duplicates when the file is re-sourced. ${_d%/} strips the trailing slash.
  case ":$PATH:" in
    # Already present -> do nothing (empty branch).
    *":${_d%/}:"*) ;;
    # Not present -> append it.
    *) PATH="$PATH:${_d%/}" ;;
  esac
done
# Clean up the loop variable so it doesn't linger in the shell environment.
unset _d
# Find a Homebrew install in any of the usual locations and, if the `brew` binary
# is executable (-x), load its environment (adds brew's bin to PATH, sets vars).
# `break` stops at the first one found so we don't run shellenv twice.
for b in /home/linuxbrew/.linuxbrew/bin/brew /opt/homebrew/bin/brew /usr/local/bin/brew; do [ -x "$b" ] && eval "$("$b" shellenv)" && break; done
# Pick a UTF-8 locale that actually exists. en_US.UTF-8 isn't generated on minimal
# boxes/containers, so LANG silently falls back to C and UTF-8 output (e.g. the box
# chars in `sch`) renders as <E2><94><80>. C.UTF-8 needs no generated locale, so use
# it as the portable fallback. Set LC_CTYPE too so character handling sticks.
# `locale -a` lists installed locales; if en_US.UTF-8 is one of them, prefer it.
# grep flags: -q quiet, -i case-insensitive, -E extended regex. The regex allows
# "utf8" or "utf-8" spellings.
if locale -a 2>/dev/null | grep -qiE '^en_US\.(utf-?8)$'; then
  export LANG=en_US.UTF-8
else
  # Fallback that needs no generated locale data — always available.
  export LANG=C.UTF-8
fi
# Make character-type handling (upper/lower, what counts as printable) match LANG.
export LC_CTYPE=$LANG
# Force a capable TERM only OUTSIDE a multiplexer. tmux/screen export their own
# TERM (tmux-256color / screen-256color) which TUIs must see to render cleanly;
# clobbering it back to xterm-256color causes escape-sequence garbage.
# -z tests for an empty string. $TMUX is set inside tmux, $STY inside GNU screen.
# So this only forces TERM when we're NOT inside a multiplexer (see note above).
if [ -z "$TMUX" ] && [ -z "$STY" ]; then export TERM=xterm-256color; fi
# Advertise 24-bit truecolor (XFCE Terminal / VTE supports it; tmux passes through)
export COLORTERM=truecolor

# Prompt color codes. Each is an ANSI escape wrapped in \[ ... \] so bash knows the
# bytes are non-printing (otherwise it miscounts line length and corrupts editing).
# 01;3x = bold + a color; 38;5;NNN = 256-color palette index; O resets to default.
GRN='\[\033[01;32m\]' R='\[\033[01;31m\]' CYAN='\[\033[01;36m\]' WHT='\[\033[01;37m\]' BLUE='\[\033[01;34m\]' MAG='\[\033[01;35m\]' GRAY='\[\033[38;5;246m\]' VGRAY='\[\033[38;5;240m\]' O='\[\033[00m\]'

# Default timezone for date/time display.
export TZ="America/Chicago"
# Build the prompt (PS1). Bash expands these backslash codes each time it's shown:
#   \u user, \h short hostname, \w current dir, \D{%F} date, \t time.
# The color variables above wrap each piece; ${vers} adds the version banner.
# The \n puts the actual "$ " input area on its own second line.
# LTZ=DST is just an unrelated exported var set on the same line.
export LTZ=DST PS1="${MAG}\u${O}@${CYAN}\h${O}:\w         ${GRAY}\D{%F} \t   ${VGRAY}${vers}${O}\n$ ${O}"
#export PS1='\[\e]0;\u@\h: \w\a\]\[\e[1;35m\]\u\[\e[0m\]@\[\e[1;36m\]\H\[\e[0m\]:\[\e[1;32m\]\w\[\e[0m\]\n\[\e[1;32m\]$\[\e[0m\] '


# For root, use a red username and a `#` prompt char as a visual "danger" cue.
if [ "$USER" == 'root' ]; then export PS1="$R\u$O@\h:\w         \D{%F} \t\n# "; fi

# PROMPT_COMMAND runs before each prompt is drawn. This escape sets the cursor to
# a blinking block (\033[5 q), keeping it consistent across programs that change it.
PROMPT_COMMAND='printf "\033[5 q"'

#bind '"\C-i":complete'  # if tab complete doesn't work
# Use vi-style command-line editing (hjkl, Esc for normal mode) at the bash prompt.
set -o vi
# Test once whether `ls` supports --color (GNU coreutils does; some BSD/macOS don't),
# discarding all output with &>/dev/null. The `if [ 0 -eq 0 ]` is always true, so
# these colorized ls aliases are always defined; the test line above is effectively
# a leftover probe. lh/lha/lhtr are common "list long, human-readable" variants.
ls --color=auto &>/dev/null; if [ 0 -eq 0 ]; then alias ls='ls --color=auto' lh='ls -lh' lha='ls -lha' lhtr='ls -lhtr'; fi;
# LESS flags: -S chop long lines, -R raw color, -F quit if it fits one screen.
# Dropped -X (was '-SRFX'): -X disables less's alternate screen, which left the
# terminal in application-cursor-key mode on exit -> trackpad scroll turned into
# bash history up/down. Without -X, less restores the screen cleanly on quit.
# EDITOR/PAGER: default programs many tools invoke. LESS sets default `less` flags.
export EDITOR=vim PAGER=less LESS='-SRF'
# Where kubectl looks for its cluster config; this path is k3s's default.
export KUBECONFIG=/etc/rancher/k3s/k3s.yaml

# ============================================================================
# ALIASES — short names that expand to longer commands. Defined alphabetically-ish.
# An alias only substitutes the FIRST word of a command line.
# ============================================================================

# Quick "go up N directories" shortcuts.
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
# `cd -` jumps back to the previous directory. The `--` lets us alias the literal "-".
alias -- -='cd -'
# Print just field 1 / field 2 / fields 1+2 of piped input. \$ escapes $ so awk (not
# bash) expands it. Handy in pipelines: `... | a1`.
alias a1="awk '{print \$1}'" a2="awk '{print \$2}'" a12="awk '{print \$1,\$2}'"
alias a='alias'
# apt package-cache shortcuts.
alias ac='apt-cache'
alias acs='apt-cache search'
# Sum a column of numbers: paste joins lines with + then bc evaluates the expression.
alias add='paste -s -d+ - | bc'
# apt-get family (all need root, hence sudo).
alias ag='sudo apt-get'
alias agud='sudo apt-get update'
# Update package lists then do a full dist-upgrade in one go.
alias agug='sudo apt-get update && sudo apt-get dist-upgrade'
alias agy='agy --dangerously-skip-permissions'
# Ansible shortcuts.
alias an='ansible'
alias ap='ansible-playbook'
alias apt='sudo apt'
# arc_summary: ZFS ARC cache stats.
alias as=arc_summary
# Astronomer (astro) CLI dev environment; asdr restarts it.
alias asd='astro dev'
alias asdr='astro dev stop && astro dev start'
# Show AWS_* env vars, truncated to 45 chars with "..." so secrets aren't fully revealed.
alias aws-creds='env | g ^AWS_ | cut -c 1-45 | sed "s/$/.../"'
alias b2=backblaze-b2
# base64 without line wrapping (-w0); bd decodes.
alias base64='base64 -w0'
alias bd='base64 -d'
alias bp='bindplane'
# Force btop to use UTF-8 box-drawing chars even when locale detection fails.
alias btop='btop --utf-force'
alias c='cat'
alias cdi='cd /etc/init.d'
# Launch Claude Code skipping permission prompts.
alias cl='claude --dangerously-skip-permissions'
