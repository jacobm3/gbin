# ============================================================================
# FUNCTIONS — used instead of aliases when arguments or multi-step logic is needed.
# ============================================================================

# gpc: git commit ALL tracked changes with the message in $1, then push.
gpc () { git commit -am "$1"; git push; }

# mcd: make a directory (and parents, -p) then cd into it.
mcd () { mkdir -p $1; cd $1; }

# print details of local certificate in a file
pcert () { openssl x509 -in $1 -text -noout; }

# print details of a remote certificate at hostname/IP addr
rcert () { openssl s_client -showcerts -connect $1:443 <<< ''; }

# print details of a remote certificate at hostname/IP addr:port
rcertport () { openssl s_client -showcerts -connect $1 <<< ''; }

# print just column N, passed in as the 1st and only argument
# similar to awk "{print $1}" but easier to type
# tr -s ' ' squeezes runs of spaces into one, then cut grabs field $1.
pc () { tr -s ' ' | cut -d ' ' -f $1; }

# convert gigabytes to bytes
gb2b () {
    # $1 is the number of gigabytes passed in.
    local gb=$1
    # bc does the multiply (it handles decimals; bash arithmetic can't).
    local bytes=$(echo "$gb * 1024 * 1024 * 1024" | bc)
    # ${bytes%.*} strips any ".000" fractional part, leaving a whole-byte count.
    echo ${bytes%.*}
}

# script session logging wrapper
logsess() {
  # Usage: logsess [description]
  # If a description is provided, it's prepended in the filename
  # followed by an ISO-like timestamp.
  
  # First argument is the optional description label for the log filename.
  local PURPOSE="$1"
  # Build a filename-safe timestamp (no colons).
  local TIMESTAMP
  TIMESTAMP=$(date +"%Y-%m-%dT%H%M%S")

  # If PURPOSE is empty, default to 'session'
  if [[ -z "$PURPOSE" ]]; then
    PURPOSE="session"
  fi

  # Combine them into the final filename
  local FILENAME="${PURPOSE}_${TIMESTAMP}.log"

  # Start the session
  # `script` records everything printed in the shell to FILENAME until you exit.
  script "$FILENAME"
}



# ============================================================================
# COMPLETION & EXTERNAL SOURCING — tab-completion wiring and other gbin helpers.
# ============================================================================

# `complete -C PROG NAME` tells bash to ask PROG itself for completions of NAME.
# This wires tab-completion through to the corresponding tool's own completer.
complete -C kubectl kc
complete -C docker d
complete -C terraform tf
complete -C vault vault
# Color scheme for `jq` output (field:object:etc. as semicolon-separated ANSI codes).
export JQ_COLORS='0;37:0;39:0;39:0;37:0;37:1;37:1;37'

# Terraform logging defaults: write debug logs to .tf.log.debug, always save plans
# to .tf.plan.out, and set log level to debug. (Used together with the tf* aliases.)
export TF_LOG_PATH=.tf.log.debug TF_CLI_ARGS_plan="-out .tf.plan.out" TF_LOG=debug

# If kubectl exists, load its bash completion and also apply it to the `k` alias.
# `source <(...)` runs the completion script that kubectl prints to stdout.
which kubectl >/dev/null && source <(kubectl completion bash) && complete -o default -F __start_kubectl k

# Load ZFS command completion if the system provides it.
if [ -e /usr/share/bash-completion/completions/zfs ]; then . /usr/share/bash-completion/completions/zfs; fi

# activate default python venv if present
#export VIRTUAL_ENV_DISABLE_PROMPT=1
#venv_path=.venv-default/bin/activate
#if [ -r "$venv_path" ]; then . .venv-default/bin/activate; fi

# custom tailscale completion
. ~/gbin/shell/complete_tailscale

# colorized `ts` wrapper for the tailscale CLI
. ~/gbin/linux/tailscale/tailscale-functions.sh

# load the bash-completion library; complete_alias relies on its
# _command_offset and _completion_loader functions for the actual completion
# `declare -F NAME` checks whether a shell function is defined; if the helper
# isn't loaded yet, source the system bash-completion library (from either path).
if ! declare -F _command_offset >/dev/null 2>&1; then
    if [ -r /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -r /etc/bash_completion ]; then
        . /etc/bash_completion
    fi
fi

# enable completion on aliases
# (so tab-completion works through the short aliases defined above, e.g. `g` -> git).
. ~/gbin/shell/complete_alias

# systemd helper functions
. ~/gbin/linux/systemd-functions.sh

# Finally, source machine-specific overrides if present. These are NOT synced by
# gbin, so they're the place for per-host secrets, paths, or tweaks. Sourced last
# so they can override anything set above.
if [ -e ~/.bashrc.local ]; then . ~/.bashrc.local; fi
if [ -e ~/.jacobrc.local ]; then . ~/.jacobrc.local; fi
