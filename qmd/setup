#!/usr/bin/env bash
# Connect this machine's Claude Code to the shared qmd memory service on the tailnet.
# Idempotent: safe to re-run. Run on every box where you use Claude Code.
set -euo pipefail

NAME="qmd"
URL="https://qmd.mink-neon.ts.net/mcp"
HEALTH="https://qmd.mink-neon.ts.net/health"

echo "==> Checking qmd service is reachable..."
if ! curl -fsS --max-time 10 "$HEALTH" >/dev/null 2>&1; then
  echo "ERROR: can't reach $HEALTH" >&2
  echo "  - Is this machine on the tailnet? (run: tailscale status)" >&2
  echo "  - Is CT 130 'qmd' on pve3 up?" >&2
  exit 1
fi
echo "    ok: $(curl -fsS "$HEALTH")"

if ! command -v claude >/dev/null 2>&1; then
  echo "ERROR: 'claude' CLI not found in PATH. Install Claude Code first." >&2
  exit 1
fi

# Re-register cleanly. 'claude mcp add' errors if the name already exists,
# so remove any prior entry first (ignore failure if it wasn't there).
echo "==> Registering MCP server '$NAME' (user scope, all projects)..."
claude mcp remove "$NAME" >/dev/null 2>&1 || true
claude mcp add --scope user --transport http "$NAME" "$URL"

echo "==> Registered. Current MCP servers:"
claude mcp list || true

cat <<EOF

Done. Claude Code on this machine can now SEARCH shared memory via the '$NAME'
MCP server (tools: query, get, multi_get, status).

To SAVE memory, use the companion script:
  $(dirname "$0")/save systems/some-fact.md <<'MD'
  # Title
  ...markdown body...
  MD

Searchable within ~5 min of saving (qmd-sync.timer on the qmd host).
EOF
